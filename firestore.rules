rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isCaretakerOf(targetUserId) {
      let targetUser = get(/databases/$(database)/documents/users/$(targetUserId)).data;
      let ownerGroupId = targetUser.ownerGroupId;
      return isAuthenticated() && 
             ownerGroupId != null && ownerGroupId != "" &&
             exists(/databases/$(database)/documents/groups/$(ownerGroupId)/members/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/groups/$(ownerGroupId)/members/$(request.auth.uid)).data.role == 'caretaker';
    }

    function isMemberOf(targetUserId) {
      let targetUser = get(/databases/$(database)/documents/users/$(targetUserId)).data;
      let ownerGroupId = targetUser.ownerGroupId;
      return isAuthenticated() && 
             ownerGroupId != null && ownerGroupId != "" &&
             exists(/databases/$(database)/documents/groups/$(ownerGroupId)/members/$(request.auth.uid));
    }

    // User Collection
    match /users/{userId} {
      allow read: if isAuthenticated(); 
      allow write: if isOwner(userId) || isCaretakerOf(userId);
      
      match /{allSubcollections=**} {
        allow read: if isOwner(userId) || isMemberOf(userId);
        allow write: if isOwner(userId);
      }
    }


    // Groups Collection
    match /groups/{groupId} {
      allow read, write: if request.auth != null;
      
      // Explicitly match members subcollection
      match /members/{memberId} {
        allow read, write: if request.auth != null;
      }
      
      // Explicitly match join_requests subcollection
      match /join_requests/{requestId} {
        allow read, write: if request.auth != null;
      }

      // Catch-all for other subcollections
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Global lists for searches
    match /users {
      allow list: if isAuthenticated();
    }
    match /groups {
      allow list: if isAuthenticated();
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
