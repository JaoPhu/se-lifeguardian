rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isCaretakerOf(targetUserId) {
      let targetUser = get(/databases/$(database)/documents/users/$(targetUserId)).data;
      let ownerGroupId = targetUser.ownerGroupId;
      return isAuthenticated() && 
             ownerGroupId != null && ownerGroupId != "" &&
             exists(/databases/$(database)/documents/groups/$(ownerGroupId)/members/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/groups/$(ownerGroupId)/members/$(request.auth.uid)).data.role.lower() == 'caretaker';
    }

    function isMemberOf(targetUserId) {
      let targetUser = get(/databases/$(database)/documents/users/$(targetUserId)).data;
      let ownerGroupId = targetUser.ownerGroupId;
      return isAuthenticated() && 
             ownerGroupId != null && ownerGroupId != "" &&
             exists(/databases/$(database)/documents/groups/$(ownerGroupId)/members/$(request.auth.uid));
    }

    // User Collection
    match /users/{userId} {
      // Profiles are readable for authenticated users (for member lists/searches)
      allow read: if isAuthenticated(); 
      allow write: if isOwner(userId) || isCaretakerOf(userId);
      
      // Subcollections (like 'events', 'notifications')
      match /{allSubcollections=**} {
        // Owners can always read/write their own subcollections
        // Others can read if they are authenticated (supports monitoring in groups)
        allow read: if isAuthenticated();
        allow write: if isOwner(userId);
      }
    }

    // Groups Collection
    match /groups/{groupId} {
      allow read, write, list: if isAuthenticated();
      
      // Subcollections
      match /{allSubcollections=**} {
        allow read, write, list: if isAuthenticated();
      }
    }
    
    // Global lists for searches
    match /users {
      allow list: if isAuthenticated();
    }
    match /groups {
      allow list: if isAuthenticated();
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
