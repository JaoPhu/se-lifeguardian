rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // User Collection: Only the user can read/write their own data
    // Allowing reading for all authenticated users to support existence checks
    // User Collection
    match /users/{userId} {
      allow read: if true; // Publicly readable for profile checks
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Subcollections (like 'events')
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Allow collection-level queries (list) for searching
    match /users {
      allow list: if true;
    }
    
    // Groups Collection
    match /groups/{groupId} {
      allow read, write: if request.auth != null;
      
      // Explicitly match members subcollection
      match /members/{memberId} {
        allow read, write: if request.auth != null;
      }
      
      // Explicitly match join_requests subcollection
      match /join_requests/{requestId} {
        allow read, write: if request.auth != null;
      }

      // Catch-all for other subcollections
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Global Groups rules for searches
    match /groups {
      allow list: if request.auth != null;
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
    
  }
}
